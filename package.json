{
  "name": "memo-tools",
  "version": "0.4.4",
  "private": true,
  "description": "meMO Tools \u2014 Langium-based SysML v2 model engine and memo CLI for medical device assurance",
  "scripts": {
    "build": "pnpm run ontology:lint && turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "memo": "node packages/tools/lib/bin/memo.js",
    "example:dev": "cd memo/examples/gpca-pump && node ../../../packages/tools/lib/bin/memo.js dev --port 3000",
    "setup": "pnpm install && pnpm run build",
    "ontology:lint": "node tools/ontology-tools/lint.mjs",
    "ontology:compat": "node tools/ontology-tools/syside-compat.mjs",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
