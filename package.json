{
  "name": "@memoarchitect/tools",
  "version": "0.4.6",
  "description": "MEMO tools — SysML v2 parser, semantic model, validation, project operations, and CLI",
  "type": "module",
  "main": "./packages/tools/lib/index.js",
  "types": "./packages/tools/lib/index.d.ts",
  "bin": {
    "memo": "packages/tools/lib/bin/memo.js"
  },
  "memo": {
    "contentPackage": "@memoarchitect/ontology"
  },
  "exports": {
    ".": {
      "types": "./packages/tools/lib/index.d.ts",
      "import": "./packages/tools/lib/index.js"
    },
    "./browser": {
      "types": "./packages/tools/lib/browser/index.d.ts",
      "import": "./packages/tools/lib/browser/index.js"
    },
    "./types": {
      "types": "./packages/tools/lib/types/index.d.ts",
      "import": "./packages/tools/lib/types/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "cd packages/tools && langium generate && tsc",
    "dev": "tsc -p packages/tools/tsconfig.json --watch",
    "test": "cd packages/tools && vitest run",
    "test:coverage": "cd packages/tools && vitest run --coverage",
    "type-check": "tsc -p packages/tools/tsconfig.json --noEmit",
    "clean": "rm -rf packages/tools/lib packages/tools/src/language/generated",
    "memo": "node packages/tools/lib/bin/memo.js",
    "example:validate": "node scripts/validate-gpca-example.mjs",
    "docs:serve": "python3 -m mkdocs serve",
    "docs:build": "python3 -m mkdocs build --strict",
    "ontology:lint": "node tools/ontology-tools/lint.mjs",
    "ontology:compat": "node tools/ontology-tools/syside-compat.mjs"
  },
  "dependencies": {
    "@memoarchitect/ontology": "0.4.6",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "glob": "^13.0.6",
    "langium": "~4.3.1",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "uuid": "^11.1.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "ws": "^8.18.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^2.1.0",
    "langium-cli": "~4.3.0",
    "typescript": "~5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "packages/tools/lib/",
    "!packages/tools/lib/__tests__/",
    "!packages/tools/lib/**/*.test.*",
    "packages/tools/src/grammar/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoarchitect/memo-tools.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
