{
  "name": "@memo/tools",
  "version": "0.4.4",
  "description": "MEMO tools — SysML v2 parser, semantic model, validation, project operations, and CLI",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "bin": {
    "memo": "./lib/bin/memo.js"
  },
  "memo": {
    "contentPackage": "@memo/ontology"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./browser": {
      "types": "./lib/browser/index.d.ts",
      "import": "./lib/browser/index.js"
    },
    "./types": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/types/index.js"
    }
  },
  "scripts": {
    "build": "langium generate && tsc",
    "dev": "langium generate --watch & tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "langium:generate": "langium generate",
    "clean": "rm -rf lib/ src/language/generated/"
  },
  "dependencies": {
    "langium": "^3.3.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "yaml": "^2.5.0",
    "uuid": "^10.0.0",
    "commander": "^12.1.0",
    "chokidar": "^4.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "open": "^10.1.0",
    "ws": "^8.18.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@memo/ontology": "workspace:*",
    "@types/ws": "^8.5.0",
    "langium-cli": "^3.3.0",
    "typescript": "~5.5.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vite": "^6.0.0"
  },
  "files": [
    "lib/",
    "!lib/__tests__/",
    "!lib/**/*.test.*",
    "src/grammar/"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
