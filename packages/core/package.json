{
  "name": "@memo/core",
  "version": "0.4.3",
  "description": "MEMO core engine — Langium SysML v2 parser, semantic model, validation, completeness tracking",
  "splitTarget": "memo-cli",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "build": "langium generate && tsc",
    "dev": "langium generate --watch & tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "langium:generate": "langium generate",
    "clean": "rm -rf lib/ src/language/generated/"
  },
  "dependencies": {
    "langium": "^3.3.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "yaml": "^2.5.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "langium-cli": "^3.3.0",
    "typescript": "~5.5.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "files": [
    "lib/",
    "src/grammar/"
  ]
}
