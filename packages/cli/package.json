{
  "name": "@memo/cli",
  "version": "0.4.4",
  "description": "MEMO CLI — init, dev, validate, build, pack commands for medical device MBSE",
  "type": "module",
  "bin": {
    "memo": "./lib/bin/memo.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf lib/"
  },
  "dependencies": {
    "@memo/core": "workspace:*",
    "@memo/ontology": "workspace:*",
    "commander": "^12.1.0",
    "chokidar": "^4.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "open": "^10.1.0",
    "ws": "^8.18.0",
    "yaml": "^2.5.0",
    "glob": "^11.0.0"
  },
  "files": [
    "lib/"
  ],
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "typescript": "~5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
