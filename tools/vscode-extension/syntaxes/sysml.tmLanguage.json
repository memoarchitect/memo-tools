{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SysML v2",
  "scopeName": "source.sysml",
  "fileTypes": ["sysml"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#doc-comment" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#definition-keywords" },
    { "include": "#usage-keywords" },
    { "include": "#behavior-keywords" },
    { "include": "#relationship-keywords" },
    { "include": "#type-keywords" },
    { "include": "#operators" },
    { "include": "#qualified-name" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sysml",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sysml",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.sysml",
              "match": "."
            }
          ]
        }
      ]
    },
    "doc-comment": {
      "patterns": [
        {
          "name": "comment.block.documentation.sysml",
          "begin": "\\bdoc\\s+/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "keyword.other.doc.sysml" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sysml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.sysml",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.sysml",
          "match": "\\b(import)\\b"
        },
        {
          "name": "keyword.control.package.sysml",
          "match": "\\b(package|library)\\b"
        },
        {
          "name": "keyword.other.sysml",
          "match": "\\b(end|connect|to|from|of|redefines|specializes|about)\\b"
        },
        {
          "name": "constant.language.boolean.sysml",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "definition-keywords": {
      "patterns": [
        {
          "name": "storage.type.definition.sysml",
          "match": "\\b(part|requirement|action|item|port|interface|connection|attribute|enum|viewpoint|view)\\s+(def)\\b",
          "captures": {
            "1": { "name": "storage.type.sysml" },
            "2": { "name": "storage.modifier.sysml" }
          }
        }
      ]
    },
    "usage-keywords": {
      "patterns": [
        {
          "name": "storage.type.usage.sysml",
          "match": "\\b(part|requirement|action|port)(?=\\s+[a-zA-Z_])",
          "captures": {
            "1": { "name": "storage.type.sysml" }
          }
        }
      ]
    },
    "behavior-keywords": {
      "patterns": [
        {
          "name": "keyword.control.behavior.sysml",
          "match": "\\b(flow|succession|first|then|start|done|allocate)\\b"
        },
        {
          "name": "keyword.other.direction.sysml",
          "match": "\\b(in|out|inout)\\b"
        }
      ]
    },
    "relationship-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.relationship.sysml",
          "match": ":>"
        },
        {
          "name": "keyword.operator.binding.sysml",
          "match": "::>"
        },
        {
          "name": "keyword.operator.namespace.sysml",
          "match": "::"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "support.type.sysml",
          "match": "\\b(String|Integer|Boolean|Real|Natural|Positive|ScalarValues)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.wildcard.sysml",
          "match": "\\*"
        }
      ]
    },
    "qualified-name": {
      "patterns": [
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.sysml"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.sysml"
        }
      ]
    }
  }
}
