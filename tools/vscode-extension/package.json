{
  "name": "memo-sysml",
  "displayName": "MEMO SysML v2",
  "description": "SysML v2 language support for MEMO — Model-Based Systems Engineering for Medical Devices",
  "version": "0.4.2",
  "publisher": "memo-mbse",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/memoarchitect/memo-tools"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "sysml",
    "sysml-v2",
    "mbse",
    "medical-device",
    "systems-engineering",
    "iso-14971",
    "iec-62304"
  ],
  "icon": "icons/memo-icon.png",
  "activationEvents": [
    "onLanguage:sysml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sysml",
        "aliases": ["SysML v2", "SysML", "sysml"],
        "extensions": [".sysml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sysml",
        "scopeName": "source.sysml",
        "path": "./syntaxes/sysml.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "plaintext",
        "path": "./snippets/memo-ears.code-snippets"
      }
    ],
    "configuration": {
      "title": "MEMO SysML",
      "properties": {
        "memoSysml.validate.onSave": {
          "type": "boolean",
          "default": true,
          "description": "Run MEMO validation on file save"
        },
        "memoSysml.validate.onType": {
          "type": "boolean",
          "default": false,
          "description": "Run MEMO validation as you type (may be slow for large models)"
        },
        "memoSysml.memoCli.path": {
          "type": "string",
          "default": "memo",
          "description": "Path to the memo CLI executable"
        }
      }
    },
    "commands": [
      {
        "command": "memoSysml.validate",
        "title": "MEMO: Validate Model"
      },
      {
        "command": "memoSysml.openViewer",
        "title": "MEMO: Open Model in Browser"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "npx @vscode/vsce package --no-dependencies",
    "clean": "rm -rf out/"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "~5.5.0",
    "@vscode/vsce": "^2.26.0"
  }
}
